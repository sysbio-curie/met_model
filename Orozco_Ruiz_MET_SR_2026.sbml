          <qual:input qual:id="tr_GSK3_in_7" qual:qualitativeSpecies="ERK" qual:sign="negative" qual:transitionEffect="none"/>
        </qual:listOfInputs>
        <qual:listOfOutputs>
          <qual:output qual:id="tr_GSK3_out" qual:qualitativeSpecies="GSK3" qual:transitionEffect="assignmentLevel"/>
        </qual:listOfOutputs>
        <qual:listOfFunctionTerms>
          <qual:defaultTerm qual:resultLevel="0">
